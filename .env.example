PORT=5000
MONGO_URI=mongodb://localhost:27017/realestate-crm
JWT_SECRET=change_this_to_a_strong_random_secret_min_32_chars
JWT_EXPIRES_IN=7d
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── Email / Nodemailer (Gmail example) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="PNH Lead MS <your_email@gmail.com>"

# ─── Meta Lead Ads Webhook ────────────────────────────────────────────────────
#
# Step-by-step setup:
# 1. Go to https://developers.facebook.com → Your App → Webhooks
# 2. Set Callback URL to: https://yourdomain.com/api/webhook/meta
# 3. Set Verify Token = META_VERIFY_TOKEN (any string you choose)
# 4. Subscribe to the "leadgen" field on Page object
# 5. Get META_APP_SECRET from: App → Settings → Basic → App Secret
# 6. Get META_ACCESS_TOKEN from: App → Tools → Graph API Explorer
#    → Select your Page → Generate Page Access Token (use long-lived token)
#
# For local testing: install ngrok, run `ngrok http 5000`
# Use the https URL from ngrok as your Callback URL

META_VERIFY_TOKEN=pick_any_string_you_want_eg_recrm2024

# From App → Settings → Basic → App Secret
META_APP_SECRET=your_meta_app_secret_here

# Page Access Token (long-lived, 60-day expiry — refresh before it expires)
META_ACCESS_TOKEN=your_page_access_token_here

# Optional: Email of the user who receives Meta leads by default
# If not set, falls back to the first admin user
META_DEFAULT_ASSIGNEE_EMAIL=raj@yourfirm.com

# Optional: If your ad is on Instagram, set this to your Instagram Page ID
# Leads from this page will be tagged as source=Instagram instead of Ads
META_INSTAGRAM_PAGE_ID=

# Optional: Map Meta Page IDs or Form IDs → CRM Project IDs for auto-assignment
# Format: JSON string — formId or pageId maps to MongoDB Project _id
# More specific (formId) takes priority over less specific (pageId)
# Example: {"FORM_ID_123": "674abc123def", "PAGE_ID_456": "674xyz789ghi"}
META_PROJECT_MAP=

# ─── Google Sheets Auto-Import ───────────────────────────────────────────────
# Secret used to authenticate incoming webhooks from Google Apps Script
SHEET_WEBHOOK_SECRET=pick_any_random_secret_string

# How often to poll Google Sheets for new leads (in minutes, default: 5)
SHEET_POLLING_INTERVAL_MINUTES=5
